# ── Copy file này thành .env.prod trên VPS ───────────────────────────────────

# ── MongoDB credentials (dùng trong docker-compose.prod.yml) ─────────────────
MONGO_USER=hanami
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ── MongoDB (tự động set bởi docker-compose, để dự phòng) ────────────────────
MONGODB_DB=hanami

# ── JWT Secrets (generate: openssl rand -hex 64) ─────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_ADMIN_SECRET=CHANGE_ME

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key
EMAIL_FROM=Hanami <no-reply@yourdomain.com>
OWNER_EMAIL=your@email.com

# ── CORS: URL của web và admin trên Vercel ────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# ── URL công khai của API (dùng cho image URLs) ───────────────────────────────
PUBLIC_URL=https://api.yourdomain.com

# ── Admin URL (dùng trong email links) ───────────────────────────────────────
ADMIN_URL=https://admin.yourdomain.com
