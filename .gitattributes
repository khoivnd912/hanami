# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files to always use LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.env*  text eol=lf
*.sh    text eol=lf

# Dockerfile
Dockerfile text eol=lf

# Binary files - never modify line endings
*.ico   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
