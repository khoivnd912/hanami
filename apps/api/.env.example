# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://hanami:hanami_secret@localhost:27017/hanami?authSource=admin
MONGODB_DB=hanami

# ── JWT Secrets (generate with: openssl rand -hex 64) ────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_ACCESS
JWT_REFRESH_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_REFRESH
JWT_ADMIN_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_ADMIN

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Hanami <no-reply@hanami.vn>
OWNER_EMAIL=owner@hanami.vn

# ── Admin dashboard URL (used in email links) ─────────────────────────────────
ADMIN_URL=http://localhost:3001

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── File uploads ──────────────────────────────────────────────────────────────
# Base URL used to build image URLs returned by POST /admin/upload
PUBLIC_URL=http://localhost:4000
